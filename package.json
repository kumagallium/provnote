{
  "name": "graphium",
  "private": true,
  "version": "0.3.6",
  "description": "Block-based note editor with PROV-DM provenance tracking — built on BlockNote.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kumagallium/Graphium.git"
  },
  "scripts": {
    "predev": "bash scripts/kill-dev.sh",
    "dev": "bash -c 'export PORT=$(cat .dev-port 2>/dev/null || echo 3001); echo \"[dev] Server port: $PORT\"; concurrently -n client,server -c blue,green \"vite\" \"PORT=$PORT tsx watch --env-file .env src/server/index.ts\"'",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file .env src/server/index.ts",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tauri": "tauri",
    "tauri:dev": "node scripts/bundle-server.mjs && tauri dev",
    "tauri:build": "tauri build",
    "bundle:server": "node scripts/bundle-server.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.60",
    "@ai-sdk/mcp": "^1.0.35",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@blocknote/core": "^0.47.0",
    "@blocknote/react": "^0.47.0",
    "@blocknote/shadcn": "^0.47.0",
    "@hono/node-server": "^1.19.13",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/plugin-opener": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "ai": "^6.0.154",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "cytoscape-fcose": "^2.2.0",
    "elkjs": "^0.11.1",
    "hono": "^4.12.12",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/cytoscape": "^3.31.0",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
