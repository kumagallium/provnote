# Google OAuth 2.0 (optional — for Google Drive sync)
# A default client ID is built into the app, so this is only needed
# if you want to use your own Google Cloud project.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Desktop app OAuth (optional — for Tauri desktop Google Drive sync)
# Create a "Desktop app" client in Google Cloud Console.
# Google treats desktop app client_secret as non-confidential (PKCE provides the security).
# See: https://developers.google.com/identity/protocols/oauth2/native-app
# VITE_GOOGLE_DESKTOP_CLIENT_ID=your-desktop-client-id.apps.googleusercontent.com
# VITE_GOOGLE_DESKTOP_CLIENT_SECRET=your-desktop-client-secret

# AI Agent Server (optional — for AI assistant features)
# Set the URL of your agent server (e.g., crucible-agent)
# You can also configure this from Settings in the Graphium sidebar.
# VITE_CRUCIBLE_AGENT_URL=http://localhost:8090

# crucible-agent API key (set same value as AGENT_API_KEY on agent server)
# VITE_CRUCIBLE_AGENT_API_KEY=your-agent-api-key
