{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Graphium",
  "version": "0.1.0",
  "identifier": "com.graphium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev:client -- --port 5174",
    "beforeBuildCommand": "node scripts/bundle-server.mjs && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Graphium",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/graphium-server"
    ],
    "resources": [
      "sidecar/server.mjs"
    ]
  }
}
