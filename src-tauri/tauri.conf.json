{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Graphium",
  "version": "0.5.0",
  "identifier": "com.graphium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "node scripts/fetch-node.mjs && node scripts/bundle-server.mjs && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Graphium",
        "url": "app/index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/graphium-server"
    ],
    "resources": [
      "sidecar/server.mjs",
      "sidecar/node"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kumagallium/Graphium/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGMzE1OTYzQTQ2QThFRQpSV1R1cUVZNmxoWHpCbDB0SXhpSlQwdGRETzZXSXJ5QnpKVW8rNi9kNTJRdmVPaUN0dW9tR3VmWgo="
    }
  }
}
