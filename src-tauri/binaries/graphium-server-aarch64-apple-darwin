#!/bin/bash
# Graphium バックエンドサーバー sidecar ラッパー
# Tauri から spawn され、Node.js でバンドル済みサーバーを起動する

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ビルド版: Contents/MacOS/ から Contents/Resources/sidecar/ を参照
SERVER_FILE="$SCRIPT_DIR/../Resources/sidecar/server.mjs"

# 開発時: Contents/sidecar/ を参照
if [ ! -f "$SERVER_FILE" ]; then
  SERVER_FILE="$SCRIPT_DIR/../sidecar/server.mjs"
fi

exec node "$SERVER_FILE" "$@"
